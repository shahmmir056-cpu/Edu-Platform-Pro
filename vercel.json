{
  "buildCommand": "cd artifacts/ai-study-hub && pnpm run build",
  "outputDirectory": "artifacts/ai-study-hub/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
